{
  "name": "carloscolbe/navia",
  "description": "A modern Laravel admin panel based on Voyager — refactored, extended, and modernized.",
  "keywords": [
    "laravel",
    "admin",
    "panel"
  ],
  "license": "MIT",
  "homepage": "https://carloscolmenarez.com/",
  "support": {
    "issues": "https://github.com/carloscolbe/navia/issues",
    "source": "https://github.com/carloscolbe/navia"
  },
  "authors": [
    {
      "name": "Carlos Colmenarez",
      "email": "me@carloscolmenarez.com",
      "role": "Maintainer"
    },
    {
      "name": "Original Voyager Team",
      "email": "support@devdojo.com",
      "homepage": "https://github.com/thedevdojo/voyager",
      "role": "Original Authors"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0|^13.0",
    "intervention/image": "^3.0",
    "intervention/image-laravel": "^1.3",
    "laravel/ui": "^4.6",
    "arrilot/laravel-widgets": "^3.15",
    "league/flysystem": "^3.0",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "illuminate/database": "^12.0|^13.0",
    "orchestra/testbench": "^10.0|^11.0",
    "laravel/browser-kit-testing": "^7.2.8",
    "orchestra/testbench-browser-kit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Navia\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Navia\\Tests\\": "tests/",
      "Navia\\Tests\\Database\\Factories\\": "tests/database/factories/",
      "Database\\Seeders\\": "vendor/orchestra/testbench-core/laravel/database/seeders"
    }
  },
  "minimum-stability": "stable",
  "extra": {
    "laravel": {
      "providers": [
        "Navia\\NaviaServiceProvider",
        "Navia\\Providers\\NaviaDummyServiceProvider"
      ]
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php vendor/bin/testbench package:discover --ansi"
    ]
  }
}
